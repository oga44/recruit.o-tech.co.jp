{
	"name": "company.kameyaweb.co.jp",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "cross-env NODE_ENV=development vite --host",
		"build": "cross-env NODE_ENV=production vite build && npm run press:images",
		"preview": "vite preview",
		"press:images": "node convert.images.mjs",
		"lint:check": "npm run lint:html && npm run lint:style && npm run lint:es",
		"lint:html": "markuplint 'resources/**/*.{html,php}'",
		"lint:style": "stylelint 'resources/assets/**/*.{css,scss}'",
		"lint:es": "eslint 'resources/assets/**/*.js'",
		"lint:fix": "markuplint 'resources/**/*.{html,php}' && stylelint --fix 'resources/assets/**/*.{css,scss}' && eslint --fix 'resources/assets/**/*.js'",
		"format": "prettier --write 'resources/**/*.{html,css,scss,js,json,php}'",
		"prepare": "husky install"
	},
	"lint-staged": {
		"*.{html,php}": "markuplint",
		"*.{js}": "eslint --fix",
		"*.{css,scss}": "stylelint --fix",
		"*.{html,css,scss,js,json,php}": "prettier --write"
	},
	"devDependencies": {
		"@markuplint/php-parser": "^3.12.0",
		"@prettier/plugin-php": "^0.22.1",
		"autoprefixer": "^10.4.16",
		"commander": "^11.1.0",
		"cross-env": "^7.0.3",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"fs-extra": "^11.2.0",
		"glob": "^10.3.10",
		"gsap": "^3.12.4",
		"husky": "^8.0.3",
		"lint-staged": "^15.2.0",
		"markuplint": "^3.15.0",
		"path": "^0.12.7",
		"postcss": "^8.4.32",
		"prettier": "^3.1.1",
		"sass": "^1.69.5",
		"sharp": "^0.33.2",
		"stylelint": "^16.0.2",
		"stylelint-config-recess-order": "^4.4.0",
		"stylelint-config-standard-scss": "^12.0.0",
		"stylelint-prettier": "^5.0.0",
		"svgo": "^3.1.0",
		"tailwindcss": "^3.4.0",
		"vite": "^5.0.8",
		"vite-plugin-browser-sync": "^3.0.2",
		"vite-plugin-live-reload": "^3.0.3",
		"vite-plugin-sass-glob-import": "^3.0.2",
		"vite-plugin-static-copy": "^1.0.0",
		"vite-plugin-svg-sprite-component": "^1.0.10",
		"vite-plugin-watch-and-run": "^1.5.1",
		"zlib": "^1.0.5"
	},
	"volta": {
		"node": "20.9.0"
	},
	"dependencies": {
		"@vitejs/plugin-react-swc": "^3.6.0",
		"lightningcss": "^1.23.0",
		"swiper": "^11.1.4"
	}
}
